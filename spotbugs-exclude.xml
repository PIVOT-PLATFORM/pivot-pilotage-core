<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                    https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

    <!--
        Squelette repris de pivot-core (même structure de filtre SpotBugs). À compléter au fil
        des premières US Pilotage (roadmap, Gantt, portefeuille) avec les mêmes patterns :
        entités JPA et beans singleton constructeur-injectés
        (fr.pivot.pilotage.*.service/.controller), cf. pivot-core/spotbugs-exclude.xml pour le
        raisonnement type.

        EI_EXPOSE_REP / EI_EXPOSE_REP2 :
          - Les entités JPA exigent des getters/setters mutables pour le fournisseur de
            persistance (Hibernate) ; des copies défensives casseraient le dirty-checking.
            Décision de conception intentionnelle, pas un bug.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Or>
            <!-- EN18.1 — Application / Project : entités JPA du socle Pilotage. -->
            <Package name="fr.pivot.pilotage.project"/>
            <!-- EN22.1a — schéma temporel : entités JPA schedule (Calendar, Task, Phase,
                 dépendances, contraintes, assignations, avancement) et baseline. -->
            <Package name="fr.pivot.pilotage.schedule"/>
            <Package name="fr.pivot.pilotage.baseline"/>
        </Or>
    </Match>

    <!--
        NM_CLASS_NOT_EXCEPTION : l'entité JPA `CalendarException` modélise un jour dérogatoire
        de calendrier (férié / ouvré exceptionnel), pas une exception Java. Le nom est un terme
        métier (table `pilotage.calendar_exception`), pas une erreur de conception.
    -->
    <Match>
        <Bug pattern="NM_CLASS_NOT_EXCEPTION"/>
        <Class name="fr.pivot.pilotage.schedule.CalendarException"/>
    </Match>

</FindBugsFilter>
